{
  "name": "gcmsg",
  "version": "0.1.0",
  "description": "Smart git commit message generator — works out of the box, no API key required",
  "type": "module",
  "bin": {
    "gcmsg": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/cli.ts --out-dir dist --format esm --clean --target node18",
    "dev": "tsup src/cli.ts --out-dir dist --format esm --clean --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["git", "commit", "conventional-commit", "cli", "developer-tools"],
  "license": "MIT",
  "engines": { "node": ">=18" }
}
